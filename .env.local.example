# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://pllqimsgbgkzffzbrwma.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# --- Threads / Meta App ---
META_APP_ID=
META_APP_SECRET=
# Must match exactly what's registered in Meta Developer App
META_REDIRECT_URI=http://localhost:3000/api/auth/threads/callback

# --- LLM via patunganai gateway (Anthropic Messages-compatible) ---
LLM_GATEWAY_API_KEY=
# Optional; defaults to the patunganai gateway URL
# LLM_GATEWAY_URL=https://patunganai-gateway.bhskin.workers.dev/v1/messages

# --- Encryption (32-byte hex; generate: openssl rand -hex 32) ---
TOKEN_ENCRYPTION_KEY=

# --- Cron auth (any random string; sent as ?secret= or Bearer header) ---
CRON_SECRET=

# --- Admin login session (32-byte hex; generate: openssl rand -hex 32) ---
SESSION_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# --- MCP Connector (32-byte hex; generate: openssl rand -hex 32) ---
# Static bearer used by claude.ai Custom Connector when calling /api/mcp
MCP_BEARER_TOKEN=

# --- Repliz API (HTTP Basic auth; from Repliz dashboard → API settings) ---
REPLIZ_API_USER=
REPLIZ_API_PASS=
# Optional; defaults to https://api.repliz.com/public
# REPLIZ_API_URL=https://api.repliz.com/public
