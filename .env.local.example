# --- Supabase ---
NEXT_PUBLIC_SUPABASE_URL=https://pllqimsgbgkzffzbrwma.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_xxx
SUPABASE_SERVICE_ROLE_KEY=eyJxxx

# --- Threads / Meta App ---
META_APP_ID=
META_APP_SECRET=
# Must match exactly what's registered in Meta Developer App
META_REDIRECT_URI=http://localhost:3000/api/auth/threads/callback

# --- LLM via OpenRouter ---
OPENROUTER_API_KEY=
OPENROUTER_MODEL_ANALYSIS=anthropic/claude-sonnet-4.6
OPENROUTER_MODEL_LIGHT=anthropic/claude-haiku-4.5

# --- Encryption (32-byte hex; generate: openssl rand -hex 32) ---
TOKEN_ENCRYPTION_KEY=

# --- Cron auth (any random string; sent as ?secret= or Bearer header) ---
CRON_SECRET=

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Single user: id of the only user row that's allowed in DB.
# After OAuth, the row is created and its UUID written here so all routes can find it.
APP_USER_ID=
